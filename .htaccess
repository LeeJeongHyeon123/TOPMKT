# .git 디렉토리에 대한 웹 접근 차단
<FilesMatch "^\.git">
    Order deny,allow
    Deny from all
</FilesMatch>

# Favicon 리다이렉션
RewriteRule ^favicon\.ico$ public/favicon.ico [L]

# .git 디렉토리 경로에 대한 접근 차단
RedirectMatch 404 /\.git

# 보안 강화를 위한 추가 설정
<FilesMatch "^/.*/\.git/">
    Order deny,allow
    Deny from all
</FilesMatch>

# PHP 파일 처리 설정
<FilesMatch "\.php$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

# 디렉토리 인덱싱 비활성화
Options -Indexes

# 기본 인덱스 파일 설정
DirectoryIndex index.php

# URL 리라이팅 설정
RewriteEngine On
RewriteBase /

# auth 경로 처리 - 리다이렉션 루프 방지
RewriteCond %{REQUEST_URI} !^/auth\.php$
RewriteRule ^auth/?$ auth.php [L]

# PHP 확장자 숨김
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [L]

# 기본 페이지 리다이렉션
RewriteRule ^$ index.php [L]
RewriteRule ^logout$ logout.php [L]

# 404 에러 페이지
ErrorDocument 404 /404.php

# 보안 헤더 설정
<IfModule mod_headers.c>
    # Content Security Policy
    Header set Content-Security-Policy "default-src 'self'; frame-src 'self' https://www.google.com https://www.gstatic.com https://www.recaptcha.net; connect-src 'self' https://www.google.com https://www.gstatic.com https://www.recaptcha.net https://*.firebaseio.com https://*.googleapis.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://www.recaptcha.net https://www.google.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:;"
    
    # 기존 보안 헤더들
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# PHP 오류 표시 설정
php_flag display_errors on
php_value error_reporting E_ALL
php_value error_log /var/log/httpd/topmkt_error.log
php_flag log_errors on
