# .git 디렉토리에 대한 웹 접근 차단
<FilesMatch "^\.git">
    Order deny,allow
    Deny from all
</FilesMatch>

# MIME 타입 설정
<IfModule mod_mime.c>
    AddType text/css .css
    AddType application/javascript .js
    AddType application/x-javascript .js
    AddType text/javascript .js
    AddType image/x-icon .ico
</IfModule>

# 파일 경로 설정
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # resources 경로를 public/assets로 리다이렉트
    RewriteRule ^resources/images/(.*)$ public/assets/images/$1 [L]
    RewriteRule ^resources/js/(.*)$ public/assets/js/$1 [L]
    RewriteRule ^resources/css/(.*)$ public/assets/css/$1 [L]
    
    # assets 파일 처리
    RewriteCond %{REQUEST_URI} ^/public/assets/(.*)$
    RewriteRule ^public/assets/(.*)$ public/assets/$1 [L]
    
    # favicon 처리
    RewriteRule ^favicon\.ico$ public/favicon.ico [L]
</IfModule>

# .git 디렉토리 경로에 대한 접근 차단
RedirectMatch 404 /\.git

# 보안 강화를 위한 추가 설정
<FilesMatch "^/.*/\.git/">
    Order deny,allow
    Deny from all
</FilesMatch>

# PHP 파일 처리 설정
<FilesMatch "\.php$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

# 디렉토리 인덱싱 비활성화
Options -Indexes

# 기본 인덱스 파일 설정
DirectoryIndex index.php

# URL 리라이팅 설정
RewriteEngine On
RewriteBase /

# auth 경로 처리 (슬래시 유무 모두 처리)
RewriteRule ^auth/?$ auth.php [L]

# PHP 확장자 숨김
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [L]

# 기본 페이지 리다이렉션
RewriteRule ^$ index.php [L]
RewriteRule ^logout$ logout.php [L]

# 404 에러 페이지
ErrorDocument 404 /404.php

# 보안 헤더 설정
<IfModule mod_headers.c>
    # Content Security Policy
    Header set Content-Security-Policy "default-src 'self'; frame-src 'self' https://www.google.com https://www.gstatic.com https://www.recaptcha.net; connect-src 'self' https://www.google.com https://www.gstatic.com https://www.recaptcha.net https://*.firebaseio.com https://*.googleapis.com https://*.firebaseapp.com https://*.firebase.googleapis.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://www.recaptcha.net https://www.google.com https://apis.google.com https://*.firebaseapp.com https://*.firebase.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; frame-ancestors 'self';"
    
    # 기존 보안 헤더들
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# PHP 오류 표시 설정
php_flag display_errors on
php_value error_reporting E_ALL
php_value error_log /var/log/httpd/topmkt_error.log
php_flag log_errors on

# PHP 설정
php_value upload_max_filesize 10M
php_value post_max_size 10M
php_value max_execution_time 300
php_value max_input_time 300

# 기본 인코딩 설정
AddDefaultCharset UTF-8

# HTTPS 강제 리다이렉션
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# www 강제 리다이렉션
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 보안 설정
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# 에러 문서 설정
ErrorDocument 500 /500.php

# 캐시 설정
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# GZIP 압축 설정
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>
